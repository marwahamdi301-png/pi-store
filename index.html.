<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Baya PiMarket</title>
    <script src="https://sdk.minepi.com/pi-sdk.js"></script>
    <style>
        body { background: #0b0b1a; color: #fff; font-family: sans-serif; text-align: center; padding: 20px; }
        .card { background: #16162d; border: 1px solid #30304f; padding: 25px; border-radius: 20px; margin-bottom: 20px; }
        button { background: #ffa500; border: none; padding: 15px 40px; border-radius: 30px; font-weight: bold; cursor: pointer; font-size: 16px; width: 100%; }
        .status { color: #aaa; margin-bottom: 15px; }
    </style>
</head>
<body>
    <h1>Baya PiMarket 🛍️</h1>
    <div class="card">
        <p class="status" id="user-info">🔒 يرجى تسجيل الدخول</p>
        <button onclick="login()">دخول آمن بـ Pi 🔴</button>
    </div>
    <div class="card">
        <h3>🤖 بوت مراقبة الحيتان (VIP)</h3>
        <p>السعر: 10 π</p>
        <button id="buy-btn" onclick="transferPi()" disabled style="opacity:0.5;">شراء الآن</button>
    </div>

    <script>
        const Pi = window.Pi;
        Pi.init({ version: "2.0", sandbox: true, appId: "70868f02-6902-4146-8800-47963d8d6491" });

        async function login() {
            try {
                const scopes = ['username', 'payments'];
                const auth = await Pi.authenticate(scopes, (p) => {});
                document.getElementById('user-info').innerText = "✅ مرحباً: " + auth.user.username;
                document.getElementById('buy-btn').disabled = false;
                document.getElementById('buy-btn').style.opacity = "1";
            } catch (err) { alert("افتح الموقع من Pi Browser"); }
        }

        async function transferPi() {
            try {
                await Pi.createPayment({
                    amount: 10,
                    memo: "شراء بوت الحيتان",
                    metadata: { type: "bot" }
                }, {
                    onReadyForServerApproval: (id) => {},
                    onReadyForServerCompletion: (id, txid) => { alert("🎉 نجحت العملية!"); },
                    onCancel: () => {},
                    onError: (e) => {}
                });
            } catch (e) { alert("حدث خطأ في الدفع"); }
        }
    </script>
</body>
</html>
